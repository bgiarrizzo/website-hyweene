# Site Generator Configuration
# Copy this file to .env and customize the values as needed
# All variables are optional - defaults will be used if not set

# URL Configuration
SITE_SCHEME=https
SITE_SHORT_URL=hyweene.fr
SITE_LONG_URL=www.hyweene.fr
SITE_BASE_URL=https://www.hyweene.fr

# Paths Configuration
SITE_RELEASES_PATH=releases
SITE_CURRENT_RELEASE_PATH=build
SITE_CONTENT_PATH=content
SITE_MEDIA_PATH=content/media
SITE_STATIC_PATH=content/static
SITE_TEMPLATE_PATH=generator/Templates
SITE_TEXT_CONTENT_PATH=content/text
SITE_BLOG_PATH=content/text/blog
SITE_LINKS_PATH=content/text/links
SITE_PAGES_PATH=content/text/pages
SITE_RESUME_PATH=content/text/resume
SITE_LEARN_PATH=content/text/learn

# Author Information
SITE_AUTHOR_NAME=Bruno Giarrizzo
SITE_AUTHOR_FULL=Bruno 'Hyweene' Giarrizzo
SITE_GITHUB_LINK=https://github.com/bgiarrizzo/
